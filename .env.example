# ============================================
# Apex - Sentient Interface Environment Config
# ============================================
# Copy this file to .env.local for local development
# For Vercel deployment, add these as Repository Secrets

# ============================================
# Grafana Cloud OpenTelemetry (Required for Metrics)
# ============================================
# Get from: https://dimakatsomoleli.grafana.net/a/grafana-setupguide-app/home

# Your Grafana Cloud OTLP Endpoint
GRAFANA_OTLP_ENDPOINT=https://otlp-gateway-prod-ap-southeast-1.grafana.net/otlp

# Your Grafana Cloud Instance ID (also called "User")
GRAFANA_INSTANCE_ID=your_instance_id

# Grafana Cloud API Key (Access Policy Token)
# Scopes: metrics:write, traces:write, logs:write
GRAFANA_API_KEY=your_api_key

# ============================================
# AI Services (At least one required)
# ============================================

# Vercel AI Gateway (preferred)
AI_GATEWAY_API_KEY=your_ai_gateway_key

# Groq API (alternative)
GROQ_API_KEY=your_groq_api_key

# ============================================
# GitHub API (Optional - for higher rate limits)
# ============================================
# Create at: https://github.com/settings/tokens
# Scope: public_repo (read-only)
GITHUB_TOKEN=ghp_your_token

# ============================================
# Application Config (Auto-set by Vercel)
# ============================================
NODE_ENV=production
VERCEL_ENV=production
VERCEL_REGION=sin1
