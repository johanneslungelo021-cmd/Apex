# ============================================
# Apex - Sentient Interface Environment Config
# ============================================
#
# IMPORTANT: For Vercel auto-deploy, add these in:
#   Vercel Dashboard → Project → Settings → Environment Variables
#
# Only use GitHub Secrets for GitHub Actions CI/CD workflows.
#
# ============================================

# ============================================
# Required Secrets (add these in Vercel)
# ============================================

# Grafana Cloud OpenTelemetry
# Get from: https://dimakatsomoleli.grafana.net/a/grafana-setupguide-app/home
GRAFANA_API_KEY=your_grafana_api_key_here
GRAFANA_INSTANCE_ID=your_instance_id_here
GRAFANA_OTLP_ENDPOINT=https://otlp-gateway-prod-ap-southeast-1.grafana.net/otlp

# AI Service (at least one required for chat)
GROQ_API_KEY=your_groq_api_key_here

# Perplexity API (for research tier queries with live web search)
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# GitHub API (optional - for higher rate limits)
# Create at: https://github.com/settings/tokens
# Scope: public_repo (read-only)
GITHUB_TOKEN=ghp_your_token_here

# ============================================
# Security Tokens (optional)
# ============================================

# Health endpoint detailed mode token
# Set this to enable detailed service status in /api/health
# Usage: curl -H "x-health-token: YOUR_TOKEN" /api/health
HEALTH_DETAILS_TOKEN=your_health_details_token_here

# IP Logging Salt for PII-safe IP hashing (HMAC-SHA256)
# If not set, IP addresses will not be hashed and logged
# Generate with: openssl rand -hex 32
IP_LOG_SALT=your_random_64_char_hex_string_here

# ============================================
# Optional Configuration
# ============================================

# AI Gateway (alternative to Groq)
AI_GATEWAY_API_KEY=your_ai_gateway_key_here

# Timeout settings (milliseconds)
GITHUB_TIMEOUT_MS=8000
AI_TIMEOUT_MS=10000

# ============================================
# Auto-set by Vercel at runtime – do NOT add here
# ============================================
# VERCEL_ENV=production
# VERCEL_REGION=sin1
# NODE_ENV=production
