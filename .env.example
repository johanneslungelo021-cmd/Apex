# ══════════════════════════════════════════════════════════════
# Apex Sentient Interface — Environment Variables
# ══════════════════════════════════════════════════════════════

# ── AI Service Keys ───────────────────────────────────────────
# Groq API key — simple + complex chat tiers
GROQ_API_KEY=your_groq_api_key_here

# Perplexity API key — research tier + news aggregation
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# Optional AI gateway
AI_GATEWAY_API_KEY=your_ai_gateway_key_here

# ── Security ──────────────────────────────────────────────────
# Required in production for pseudonymized IP logging.
# Generate with: openssl rand -hex 32
IP_LOG_SALT=

# Internal health diagnostics token
HEALTH_DETAILS_TOKEN=your_health_token_here

# ── Observability ─────────────────────────────────────────────
# Canonical runtime configuration used by @vercel/otel
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=

# Optional source variables for generating OTEL values
# OTEL_EXPORTER_OTLP_HEADERS should be:
# Authorization=Basic base64(instanceId:apiKey)
GRAFANA_API_KEY=
GRAFANA_INSTANCE_ID=
GRAFANA_OTLP_ENDPOINT=

# ── GitHub integration ───────────────────────────────────────
GITHUB_TOKEN=ghp_your_token_here

# ── Supabase (persistent user database) ──────────────────────
# Project URL — get from: Settings → API → Project URL
SUPABASE_URL=https://xdkojaigrjhzjkqxguxh.supabase.co
# Service role key — get from: Settings → API → Project API keys → service_role
# KEEP THIS SERVER-SIDE ONLY. Never expose to the browser or commit to git.
SUPABASE_SERVICE_ROLE_KEY=

# ── Optional timeouts (milliseconds) ─────────────────────────
# GROQ_TIMEOUT_MS=15000
# PERPLEXITY_TIMEOUT_MS=14000
# AI_TIMEOUT_MS=15000
# GITHUB_TIMEOUT_MS=5000
