# ============================================
# Apex - Sentient Interface Environment Config
# ============================================

# GitHub API Token
# Create at: https://github.com/settings/tokens
# Required scopes: public_repo (read-only)
# Increases rate limit from 60 to 5000 requests/hour
GITHUB_TOKEN=ghp_YOUR_TOKEN_HERE

# LocalAI Configuration
LOCALAI_URL=http://localhost:8080
LOCALAI_MODEL=llama-3.3-70b

# ============================================
# Grafana Cloud OpenTelemetry Configuration
# ============================================
# Find these values at: https://dimakatsomoleli.grafana.net/a/grafana-setupguide-app/home
# Or go to: Configuration > OpenTelemetry

# OTLP Endpoint (region-specific)
# Options: us-central1, eu-west1, etc.
GRAFANA_OTLP_ENDPOINT=https://otlp-gateway-prod-us-central1.grafana.net/otlp

# Your Grafana Cloud Instance ID (also called "User" or "username" in basic auth)
# Find in: Configuration > OpenTelemetry > Instance ID
GRAFANA_INSTANCE_ID=YOUR_INSTANCE_ID

# Grafana Cloud API Key (or Access Policy Token)
# Create at: Configuration > Access Policies > Create Token
# Required scope: metrics:write, traces:write, logs:write
GRAFANA_API_KEY=YOUR_API_KEY

# ============================================
# Grafana Alloy Configuration (Alternative)
# ============================================
# For local Prometheus scraping via Alloy
GRAFANA_ALLOY_URL=http://localhost:9090

# ============================================
# Application Configuration
# ============================================
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
