# ══════════════════════════════════════════════════════════════
# Apex Sentient Interface — Environment Variables
# Copy this file to .env.local for local development.
# Never commit real values — add them to Vercel Dashboard instead.
# ══════════════════════════════════════════════════════════════

# ── AI Service Keys ───────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
PERPLEXITY_API_KEY=your_perplexity_api_key_here
AI_GATEWAY_API_KEY=your_ai_gateway_key_here

# ── Supabase (Postgres DB) ────────────────────────────────────
# Get these from: https://supabase.com/dashboard/project/<your-project-ref>/settings/api
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SECRET_KEY=your_service_role_secret_here
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_JWT_SECRET=your_jwt_secret_here
SUPABASE_PUBLISHABLE_KEY=your_publishable_key_here

# Public vars (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_key_here

# ── Postgres direct connection (for migrations / Prisma if needed) ──
POSTGRES_PRISMA_URL=your_prisma_url_here
POSTGRES_URL_NON_POOLING=your_non_pooling_url_here
POSTGRES_USER=your_db_user_here
POSTGRES_HOST=your_db_host_here
POSTGRES_PASSWORD=your_db_password_here
POSTGRES_DATABASE=your_db_name_here

# ── Auth ────────────────────────────────────────────────────────
# Used by src/lib/auth/session.ts to sign JWTs.
# MUST be named AUTH_SECRET — session.ts reads process.env.AUTH_SECRET.
# Generate with: openssl rand -hex 32
AUTH_SECRET=generate_with_openssl_rand_hex_32

# ── Security ──────────────────────────────────────────────────
# Required in production for pseudonymized IP logging.
IP_LOG_SALT=generate_with_openssl_rand_hex_32
HEALTH_DETAILS_TOKEN=your_health_token_here

# ── Observability ─────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
GRAFANA_API_KEY=
GRAFANA_INSTANCE_ID=
GRAFANA_OTLP_ENDPOINT=

# ── GitHub integration ─────────────────────────────────────────
GITHUB_TOKEN=ghp_your_token_here

# ── XRPL (optional) ──────────────────────────────────────────────
XRPL_SERVICE_URL=https://your-python-xrpl-service/submit

# ── Optional timeouts (milliseconds) ──────────────────────────
# GROQ_TIMEOUT_MS=15000
# PERPLEXITY_TIMEOUT_MS=14000
# AI_TIMEOUT_MS=15000
# GITHUB_TIMEOUT_MS=5000
