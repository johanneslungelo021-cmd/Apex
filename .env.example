# ============================================
# Apex — Sentient Interface Environment Config
# Phase 2 — Intelligent Engine + Live News
# ============================================
#
# Add all variables in:
#   Vercel Dashboard → Project → Settings → Environment Variables
#
# ============================================
# Required — without these, core features fail
# ============================================

# Groq — powers the Intelligent Engine + Scout Agent
# Create at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Perplexity — powers live news search
# Create at: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# Grafana Cloud OTLP — metrics & tracing pipeline
# Get from: https://grafana.com/profile/org → My Account → OpenTelemetry
GRAFANA_API_KEY=your_grafana_api_key_here
GRAFANA_INSTANCE_ID=your_instance_id_here
GRAFANA_OTLP_ENDPOINT=https://otlp-gateway-prod-ap-southeast-1.grafana.net/otlp

# ============================================
# Required — security-critical
# ============================================

# HMAC key for PII-safe IP hashing in rate-limit logs.
# If unset, IP field is omitted entirely (no false protection).
# Generate: openssl rand -hex 32
IP_LOG_SALT=your_random_hex_salt_here

# JWT signing secret for session tokens (Phase 3 auth).
# Generate: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_here

# Notion news ingest shared secret (Phase 3).
# Used to authenticate POST /api/notion/ingest from your automation.
# Generate: openssl rand -hex 32
NOTION_INGEST_SECRET=your_notion_ingest_secret_here

# ============================================
# Optional — enhances reliability
# ============================================

# Health endpoint internal-details token
# Usage: curl -H "x-health-token: TOKEN" /api/health
HEALTH_DETAILS_TOKEN=your_health_details_token_here

# GitHub API (raises rate limits for /api/metrics)
# Scope: public_repo read-only
GITHUB_TOKEN=ghp_your_token_here

# Timeout overrides (milliseconds)
GROQ_TIMEOUT_MS=15000
PERPLEXITY_TIMEOUT_MS=14000
AI_TIMEOUT_MS=10000
GITHUB_TIMEOUT_MS=8000

# ============================================
# Auto-set by Vercel — do NOT add here
# ============================================
# VERCEL_ENV=production
# VERCEL_REGION=sin1
# NODE_ENV=production
