# ══════════════════════════════════════════════════════════════
# Apex Sentient Interface — Environment Variables
# ══════════════════════════════════════════════════════════════

# ── AI Service Keys ───────────────────────────────────────────
# Groq API key — used for llama-3.1-8b-instant (simple tier)
# and llama-3.3-70b-versatile (complex tier) inference
# Get yours at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Perplexity API key — used for live web search (research tier)
# and news aggregation via Perplexity Search API
# Get yours at: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# AI Gateway key — optional routing/caching proxy
AI_GATEWAY_API_KEY=your_ai_gateway_key_here

# ── Security ──────────────────────────────────────────────────
# IP Log Salt — REQUIRED for production PII-safe logging.
# Used with HMAC-SHA256 to pseudonymize client IPs before logging.
# If not set, IP-based logging is silently disabled (no fallback).
# Generate with: openssl rand -hex 32
IP_LOG_SALT=

# Health endpoint details token
HEALTH_DETAILS_TOKEN=your_health_token_here

# ── Observability (Grafana Cloud OTEL) ────────────────────────
# All required for OpenTelemetry export to Grafana Cloud.
# Get these from: Grafana Cloud → Connections → OpenTelemetry
GRAFANA_API_KEY=your_grafana_api_key_here
GRAFANA_INSTANCE_ID=your_instance_id_here
GRAFANA_OTLP_ENDPOINT=https://otlp-gateway-prod-ap-southeast-1.grafana.net/otlp

# OTEL headers — format: Authorization=Basic base64(instanceId:apiKey)
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=

# ── GitHub Integration (optional) ─────────────────────────────
# Increases GitHub API rate limit from 60 to 5,000 req/hr
GITHUB_TOKEN=ghp_your_token_here

# ── Timeout Configuration (optional, in milliseconds) ────────
# GROQ_TIMEOUT_MS=15000
# PERPLEXITY_TIMEOUT_MS=14000
# AI_TIMEOUT_MS=15000
# GITHUB_TIMEOUT_MS=5000
