    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\nconst documents = Array.isArray(input) ? input : (input.documents || input.results || [input]);\n\nconst sorted = documents\n  .filter(d => d && typeof d.rerank_score === 'number')\n  .sort((a, b) => b.rerank_score - a.rerank_score)\n  .slice(0, 5);\n\nreturn [{ json: { top_memories: sorted } }];"
      },
