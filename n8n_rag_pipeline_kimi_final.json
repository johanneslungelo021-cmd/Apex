    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\nconst response = input.response || input;\nconst faithfulness = typeof response.faithfulness_score === 'number' ? response.faithfulness_score : (typeof input.faithfulness_score === 'number' ? input.faithfulness_score : 0.8);\nconst relevance = typeof response.relevance_score === 'number' ? response.relevance_score : (typeof input.relevance_score === 'number' ? input.relevance_score : 0.7);\n\nconst passed = faithfulness >= 0.7 && relevance >= 0.6;\n\nif (!passed) {\n  return [{ json: {\n    eval_passed: false,\n    faithfulness_score: faithfulness,\n    relevance_score: relevance,\n    answer: 'I was unable to generate a sufficiently reliable answer. Please rephrase your query or provide more context.',\n    fallback: true,\n    original_response: input\n  }}];\n}\n\nreturn [{ json: {\n  eval_passed: true,\n  faithfulness_score: faithfulness,\n  relevance_score: relevance,\n  answer: input.response || input.text || input,\n  fallback: false,\n  original_response: input\n}}];"
