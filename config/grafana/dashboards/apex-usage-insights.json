  "liveNow": false,
  "panels": [
    {
      "datasource": {
        "type": "loki",
        "uid": "grafanacloud-usage-insights"
      },
      "description": "Count of dashboard data-request events over time, sourced from Grafana usage insights logs.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "fixedColor": "#2196F3",
            "mode": "fixed"
          },
          "custom": {
            "barAlignment": 0,
            "drawStyle": "bars",
            "fillOpacity": 80,
            "gradientMode": "opacity",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "showPoints": "never",
            "spanNulls": false
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": 0
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "pluginVersion": "11.5.0",
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "grafanacloud-usage-insights"
          },
          "expr": "count_over_time({service_name=\"grafana\"} |= \"data-request\" [$__auto])",
          "hide": false,
          "legendFormat": "Query Events",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "📊 Dashboard Query Events",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "grafanacloud-usage-insights"
      },
      "description": "Average time to execute dashboard data-request queries in milliseconds, from Grafana usage logs.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "fixedColor": "#FF9800",
            "mode": "fixed"
          },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "gradientMode": "opacity",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "showPoints": "auto",
            "spanNulls": false
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 500
              },
              {
                "color": "red",
                "value": 2000
              }
            ]
          },
          "unit": "ms"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "pluginVersion": "11.5.0",
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "grafanacloud-usage-insights"
          },
          "expr": "avg_over_time({service_name=\"grafana\"} |= \"data-request\" | logfmt | duration != \"\" | unwrap duration [$__auto])",
          "hide": false,
          "legendFormat": "Avg Duration",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "⏱ Avg Dashboard Query Duration",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "grafanacloud-usage-insights"
      },
      "description": "Total dashboard query events broken down by datasource type over the selected time range.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "options": {
        "displayLabels": [
          "name",
          "percent"
        ],
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true,
          "values": [
            "percent",
            "value"
          ]
        },
        "pieType": "donut",
        "reduceOptions": {
          "calcs": [
            "sum"
          ],
          "fields": "",
          "values": false
        },
        "tooltip": {
          "mode": "single",
          "sort": "desc"
        }
      },
      "pluginVersion": "11.5.0",
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "grafanacloud-usage-insights"
          },
          "expr": "sum by(datasourceName) (count_over_time({service_name=\"grafana\"} |= \"data-request\" | logfmt [$__auto]))",
          "hide": false,
          "legendFormat": "{{datasourceName}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "🗂 Queries by Datasource",
      "type": "piechart"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "grafanacloud-usage-insights"
      },
      "description": "Real-time stream of Grafana dashboard query events from usage insights. Shows who queried what panel, which datasource, and how long it took.",
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 16
      },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "pluginVersion": "11.5.0",
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "grafanacloud-usage-insights"
          },
          "expr": "{service_name=\"grafana\"} |= \"data-request\" | logfmt | line_format \"[{{.username}}] {{.dashboardName}} › {{.panelName}} via {{.datasourceName}} ({{.duration}}ms)\"",
          "hide": false,
          "range": true,
          "refId": "A"
        }
      ],
      "title": "📋 Live Dashboard Activity Logs",
      "type": "logs"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 41,
